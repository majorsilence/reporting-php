{
    "name": "majorsilence/reporting",
    "description": "PHP wrappers for Majorsilence Reporting (.NET)",
    "type": "library",
    "license": "LGPL-2.1-only",
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MajorsilenceReporting\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MajorsilenceReporting\\Tests\\": "tests/"
        }
    }
}
